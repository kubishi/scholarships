{
  "name": "lmu-indigenous-scholarships",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "preview": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute scholarships-db --file=src/schema.sql",
    "db:migrate:local": "wrangler d1 execute scholarships-db --file=src/schema.sql --local",
